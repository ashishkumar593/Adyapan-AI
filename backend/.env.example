# ======================
# Backend Environment Variables
# ======================
# Copy this file to .env and fill in your values.
# For Railway, set these in your service's Variables tab.

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=verify-full
MASTER_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# --- Neon API (for per-user database provisioning) ---
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_BRANCH_ID=
NEON_REGION_ID=aws-us-east-1

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Security ---
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_REGISTER_SECRET=change-this-to-a-long-random-secret

# --- Frontend (for CORS) ---
FRONTEND_URL=https://adyapan-ai-gamma.vercel.app

# --- AI Providers ---
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- File Storage (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_TEST_KEY_SECRET

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# --- Codeforces ---
CODEFORCES_API_KEY=
CODEFORCES_API_SECRET=

# --- NVIDIA (Embedding) ---
NVIDIA_API_KEY=

# --- Piston Code Execution ---
PISTON_URL=http://localhost:2000

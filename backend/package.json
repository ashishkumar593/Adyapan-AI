  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "npx prisma generate && npx prisma generate --schema=prisma/schema.user.prisma && tsc",
    "start": "node dist/index.js",
    "postinstall": "npx prisma generate && npx prisma generate --schema=prisma/schema.user.prisma",
    "prisma:generate": "npx prisma generate && npx prisma generate --schema=prisma/schema.user.prisma",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:user": "prisma migrate deploy --schema=prisma/schema.user.prisma",
    "migrate:all": "ts-node src/scripts/migrate-all.ts",
    "db:reset-all": "ts-node src/scripts/reset-databases.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",

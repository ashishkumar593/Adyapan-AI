generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  profile   Profile?

  @@map("users")
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  username          String?
  phone             String?
  location          String?
  aboutMe           String?  @map("about_me")
  college           String?
  branch            String?
  degree            String?
  year              String?
  graduationYear    String?  @map("graduation_year")
  skills            String[] @default([])
  interestedDomains String[] @default([]) @map("interested_domains")
  targetRole        String?  @map("target_role")
  careerGoal        String?  @map("career_goal")
  careerObjective   String?  @map("career_objective")
  linkedin          String?
  github            String?
  portfolio         String?
  resumeUrl         String?  @map("resume_url")
  resumeName        String?  @map("resume_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  profile   Profile?

  resumes         Resume[]
  atsReports      ATSReport[]
  resumeAnalyses  ResumeAnalysis[]
  coverLetters    CoverLetter[]
  linkedinReports LinkedInReport[]

  // Learning Hub Relations
  studySessions   StudySession[]
  uploadedDocs    UploadedDocument[]
  generatedNotes  GeneratedNote[]
  quizzes         Quiz[]
  quizAttempts    QuizAttempt[]
  flashcards      Flashcard[]
  assignments     Assignment[]
  presentations   Presentation[]
  mindMaps        MindMap[]

  // Coding Hub Relations
  codingSessions      CodingSession[]
  submissions         Submission[]
  dsaProgress         DSAProgress[]
  challengeSubmissions ChallengeSubmission[]
  leaderboards        Leaderboard[]
  portfolios          Portfolio[]
  githubProfiles      GithubProfile[]
  generatedReadmes    GeneratedReadme[]

  // Interview Hub Relations
  interviewSessions   InterviewSession[]

  // Ady Chat Relations
  chatSessions        ChatSession[]

  @@map("users")
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  username          String?
  phone             String?
  location          String?
  aboutMe           String?  @map("about_me")
  college           String?
  branch            String?
  degree            String?
  year              String?
  graduationYear    String?  @map("graduation_year")
  skills            String[] @default([])
  interestedDomains String[] @default([]) @map("interested_domains")
  targetRole        String?  @map("target_role")
  careerGoal        String?  @map("career_goal")
  careerObjective   String?  @map("career_objective")
  linkedin          String?
  github            String?
  portfolio         String?
  resumeUrl         String?  @map("resume_url")
  resumeName        String?  @map("resume_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Resume {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  title          String
  template       String
  personalInfo   Json             @map("personal_info")
  education      Json
  experience     Json
  projects       Json
  skills         Json
  certifications Json
  achievements   Json?
  languages      Json?
  targetCompany  String?          @map("target_company")
  pdfUrl         String?          @map("pdf_url")
  docxUrl        String?          @map("docx_url")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  atsReports     ATSReport[]
  resumeAnalyses ResumeAnalysis[]
  coverLetters   CoverLetter[]

  @@map("resumes")
}

model ATSReport {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  resumeId        String   @map("resume_id")
  score           Int
  missingKeywords Json     @map("missing_keywords")
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("ats_reports")
}

model ResumeAnalysis {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  resumeId        String   @map("resume_id")
  strengths       Json
  weaknesses      Json
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("resume_analyses")
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  resumeId       String?  @map("resume_id")
  companyName    String   @map("company_name")
  role           String
  jobDescription String?  @map("job_description")
  tone           String   @default("Professional")
  letterType     String   @default("Full-Time") @map("letter_type")
  greeting       String?
  introduction   String?
  body           String?
  closing        String?
  content        String
  pdfUrl         String?  @map("pdf_url")
  docxUrl        String?  @map("docx_url")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume         Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@map("cover_letters")
}

model LinkedInReport {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  headline        String
  aboutSection    String   @map("about_section")
  skills          Json
  recommendations Json
  score           Int
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("linkedin_reports")
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  topic     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  StudyMessage[]
  documents UploadedDocument[]

  @@map("study_sessions")
}

model StudyMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String   // "user" or "model"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("study_messages")
}

model UploadedDocument {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  sessionId String?  @map("session_id")
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type")
  createdAt DateTime @default(now()) @map("created_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   StudySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("uploaded_documents")
}

model GeneratedNote {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  subject    String?
  difficulty String?
  type       String   // "detailed", "short", "revision", "formula", "exam"
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_notes")
}

model Quiz {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  difficulty String?
  questions  Json
  createdAt  DateTime @default(now()) @map("created_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts   QuizAttempt[]
  flashcards Flashcard[]

  @@map("quizzes")
}

model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  quizId       String   @map("quiz_id")
  score        Int
  total        Int
  accuracy     Float
  weakTopics   String[] @map("weak_topics")
  strongTopics String[] @map("strong_topics")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model Flashcard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  quizId    String?  @map("quiz_id")
  topic     String
  front     String
  back      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz?   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

model Assignment {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  topic         String
  academicLevel String   @map("academic_level")
  wordCount     Int      @map("word_count")
  content       Json     // Introduction, Body, Conclusion, References
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assignments")
}

model Presentation {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  slideCount Int      @map("slide_count")
  audience   String?
  style      String?
  slides     Json     // Array of Slide Content
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presentations")
}

model MindMap {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  topic     String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mind_maps")
}

// ==========================================
// Coding Hub Models
// ==========================================

model CodingSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  language  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages  CodingMessage[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coding_sessions")
}

model CodingMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String   // "user" or "model"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  session   CodingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("coding_messages")
}

// ------------------------------------------
// DSA Practice Models
// ------------------------------------------

model Problem {
  id          String   @id @default(cuid())
  title       String
  difficulty  String   // "Easy", "Medium", "Hard"
  category    String   // e.g., "Arrays", "DP"
  companies   String[] // e.g., ["Google", "Amazon"]
  statement   String
  constraints String
  examples    Json
  hints       String[]
  editorial   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  submissions Submission[]

  @@map("problems")
}

model Submission {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  problemId String   @map("problem_id")
  code      String
  language  String
  status    String   // "Accepted", "Wrong Answer", "Time Limit Exceeded"
  timeMs    Int?
  memoryKb  Int?
  aiReview  Json?    // Stores Time/Space Complexity & Optimization Tips
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model DSAProgress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  solved    Int      @default(0)
  accuracy  Float    @default(0)
  streak    Int      @default(0)
  ranking   Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dsa_progress")
}

// ------------------------------------------
// Coding Challenges Models
// ------------------------------------------

model Challenge {
  id          String   @id @default(cuid())
  title       String
  difficulty  String   // "Easy", "Medium", "Hard"
  points      Int
  description String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  submissions ChallengeSubmission[]

  @@map("challenges")
}

model ChallengeSubmission {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  code        String
  language    String
  score       Int      @default(0)
  status      String   // "Accepted", "Failed"
  createdAt   DateTime @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@map("challenge_submissions")
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  score     Int      @default(0)
  rank      Int?
  badges    String[]
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leaderboards")
}

// ------------------------------------------
// GitHub Portfolio Builder Models
// ------------------------------------------

model GithubProfile {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  username    String
  repos       Json     // Processed repo data
  languages   Json     // Language stats
  stars       Int      @default(0)
  commits     Int      @default(0)
  lastSynced  DateTime @default(now()) @map("last_synced")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("github_profiles")
}

model GeneratedReadme {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  projectName String
  content     String
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_readmes")
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  theme       String   @default("default")
  content     Json     // Configured sections (Home, About, Projects)
  isPublished Boolean  @default(false)
  url         String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

// ==========================================
// Interview Hub Models
// ==========================================

model InterviewSession {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  role       String
  company    String?
  type       String   // "technical", "behavioral", "general"
  difficulty String   @default("medium")
  status     String   @default("in_progress") // "in_progress", "completed"
  feedback   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   InterviewMessage[]

  @@map("interview_sessions")
}

model InterviewMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String   // "user", "interviewer", "feedback"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_messages")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String   @default("New Chat")
  model     String   @default("openai/gpt-4o-mini")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

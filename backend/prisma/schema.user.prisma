generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/user-client"
}

datasource db {
  provider = "postgresql"
}

model Resume {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  title          String
  template       String
  personalInfo   Json             @map("personal_info")
  education      Json
  experience     Json
  projects       Json
  skills         Json
  certifications Json
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  achievements   Json?
  docxUrl        String?          @map("docx_url")
  languages      Json?
  pdfUrl         String?          @map("pdf_url")
  targetCompany  String?          @map("target_company")
  atsReports     ATSReport[]
  coverLetters   CoverLetter[]
  resumeAnalyses ResumeAnalysis[]

  @@map("resumes")
}

model ATSReport {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  resumeId        String   @map("resume_id")
  score           Int
  missingKeywords Json     @map("missing_keywords")
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("ats_reports")
}

model ResumeAnalysis {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  resumeId        String   @map("resume_id")
  strengths       Json
  weaknesses      Json
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("resume_analyses")
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  companyName    String   @map("company_name")
  role           String
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  resumeId       String?  @map("resume_id")
  jobDescription String?  @map("job_description")
  tone           String   @default("Professional")
  letterType     String   @default("Full-Time") @map("letter_type")
  greeting       String?
  introduction   String?
  body           String?
  closing        String?
  pdfUrl         String?  @map("pdf_url")
  docxUrl        String?  @map("docx_url")
  resume         Resume?  @relation(fields: [resumeId], references: [id])

  @@map("cover_letters")
}

model LinkedInReport {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  headline        String
  aboutSection    String   @map("about_section")
  skills          Json
  recommendations Json
  score           Int
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("linkedin_reports")
}

model StudySession {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  topic     String
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  messages  StudyMessage[]
  documents UploadedDocument[]

  @@map("study_sessions")
}

model StudyMessage {
  id        String       @id @default(cuid())
  sessionId String       @map("session_id")
  role      String
  content   String
  createdAt DateTime     @default(now()) @map("created_at")
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("study_messages")
}

model UploadedDocument {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  sessionId String?       @map("session_id")
  fileName  String        @map("file_name")
  fileUrl   String        @map("file_url")
  fileType  String        @map("file_type")
  createdAt DateTime      @default(now()) @map("created_at")
  session   StudySession? @relation(fields: [sessionId], references: [id])

  @@map("uploaded_documents")
}

model GeneratedNote {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  subject    String?
  difficulty String?
  type       String
  content    String
  formattedContent String? @map("formatted_content")
  pdfUrl     String?  @map("pdf_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("generated_notes")
}

model Quiz {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  topic      String
  difficulty String?
  questions  Json
  createdAt  DateTime      @default(now()) @map("created_at")
  flashcards Flashcard[]
  attempts   QuizAttempt[]

  @@map("quizzes")
}

model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  quizId       String   @map("quiz_id")
  score        Int
  total        Int
  accuracy     Float
  weakTopics   String[] @map("weak_topics")
  strongTopics String[] @map("strong_topics")
  createdAt    DateTime @default(now()) @map("created_at")
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model Flashcard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  quizId    String?  @map("quiz_id")
  topic     String
  front     String
  back      String
  createdAt DateTime @default(now()) @map("created_at")
  quiz      Quiz?    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

model Assignment {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  topic         String
  academicLevel String   @map("academic_level")
  wordCount     Int      @map("word_count")
  content       Json
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("assignments")
}

model Presentation {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  slideCount Int      @map("slide_count")
  audience   String?
  style      String?
  slides     Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("presentations")
}

model MindMap {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  topic     String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("mind_maps")
}

model CodingSession {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  title     String
  language  String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  messages  CodingMessage[]

  @@map("coding_sessions")
}

model CodingMessage {
  id        String        @id @default(cuid())
  sessionId String        @map("session_id")
  role      String
  content   String
  createdAt DateTime      @default(now()) @map("created_at")
  session   CodingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("coding_messages")
}

model Problem {
  id          String       @id @default(cuid())
  title       String
  difficulty  String
  category    String
  companies   String[]
  statement   String
  constraints String
  examples    Json
  hints       String[]
  editorial   String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  submissions Submission[]

  @@map("problems")
}

model Submission {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  problemId String   @map("problem_id")
  code      String
  language  String
  status    String
  timeMs    Int?
  memoryKb  Int?
  aiReview  Json?
  createdAt DateTime @default(now()) @map("created_at")
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model DSAProgress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  solved    Int      @default(0)
  accuracy  Float    @default(0)
  streak    Int      @default(0)
  ranking   Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dsa_progress")
}

model Challenge {
  id          String                @id @default(cuid())
  title       String
  difficulty  String
  points      Int
  description String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime              @default(now()) @map("created_at")
  submissions ChallengeSubmission[]

  @@map("challenges")
}

model ChallengeSubmission {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  challengeId String    @map("challenge_id")
  code        String
  language    String
  score       Int       @default(0)
  status      String
  createdAt   DateTime  @default(now()) @map("created_at")
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@map("challenge_submissions")
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  score     Int      @default(0)
  rank      Int?
  badges    String[]
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("leaderboards")
}

model GithubProfile {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  username   String
  repos      Json
  languages  Json
  stars      Int      @default(0)
  commits    Int      @default(0)
  lastSynced DateTime @default(now()) @map("last_synced")

  @@map("github_profiles")
}

model GeneratedReadme {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  projectName String
  content     String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("generated_readmes")
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  theme       String   @default("default")
  content     Json
  isPublished Boolean  @default(false)
  url         String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("portfolios")
}

model InterviewSession {
  id                   String             @id @default(cuid())
  userId               String             @map("user_id")
  role                 String
  company              String?
  type                 String
  difficulty           String             @default("medium")
  language             String             @default("english")
  durationMinutes      Int                @default(30)
  technology           String?
  aiVoiceEnabled       Boolean            @default(true) @map("ai_voice_enabled")
  videoEnabled         Boolean            @default(true) @map("video_enabled")
  status               String             @default("in_progress")
  violationPoints      Int                @default(0) @map("violation_points")
  violationThreshold   Int                @default(10) @map("violation_threshold")
  feedback             Json?
  configuration        Json?
  identityVerification Json?              @map("identity_verification")
  deviceInfo           Json?              @map("device_info")
  systemCheck          Json?              @map("system_check")
  startedAt            DateTime?          @map("started_at")
  endedAt              DateTime?          @map("ended_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  messages             InterviewMessage[]
  violations           ProctoringEvent[]
  evaluations          InterviewEvaluation[]

  @@map("interview_sessions")
}

model InterviewMessage {
  id        String           @id @default(cuid())
  sessionId String           @map("session_id")
  role      String
  content   String
  audioUrl  String?          @map("audio_url")
  duration  Int?             @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_messages")
}

model ProctoringEvent {
  id              String           @id @default(cuid())
  sessionId       String           @map("session_id")
  eventType       String           @map("event_type")
  category        String
  description     String
  confidence      Float            @default(0)
  screenshotData  String?          @map("screenshot_data")
  severity        String           @default("info")
  actionTaken     String?          @map("action_taken")
  pointsDeducted  Int              @default(0) @map("points_deducted")
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  session         InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("proctoring_events")
}

model InterviewEvaluation {
  id                String           @id @default(cuid())
  sessionId         String           @map("session_id")
  overallScore      Int              @map("overall_score")
  communicationScore Int             @map("communication_score")
  technicalScore    Int?             @map("technical_score")
  hrScore           Int?             @map("hr_score")
  confidenceScore   Int?             @map("confidence_score")
  fluencyScore      Int?             @map("fluency_score")
  bodyLanguageScore Int?             @map("body_language_score")
  strengths         Json
  weaknesses        Json
  improvements      Json
  summary           String
  hiringRecommendation String        @map("hiring_recommendation")
  detailedAnalysis  Json?            @map("detailed_analysis")
  createdAt         DateTime         @default(now()) @map("created_at")
  session           InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_evaluations")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  title     String        @default("New Chat")
  model     String        @default("openai/gpt-4o-mini")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  role      String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model LearningAnalytics {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  documentsCount     Int      @default(0) @map("documents_count")
  studyTimeMinutes   Int      @default(0) @map("study_time_minutes")
  conceptsLearned    Int      @default(0) @map("concepts_learned")
  learningScore      Int      @default(0) @map("learning_score")
  examReadiness      Int      @default(0) @map("exam_readiness")
  currentStreak      Int      @default(0) @map("current_streak")
  longestStreak      Int      @default(0) @map("longest_streak")
  toolUsageJson      Json     @map("tool_usage_json")
  topicAnalyticsJson Json     @map("topic_analytics_json")
  recommendationsJson Json    @map("recommendations_json")
  insightsJson       Json     @map("insights_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("learning_analytics")
}

model LearningEvent {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  eventType  String   @map("event_type")
  documentId String?  @map("document_id")
  toolUsed   String?  @map("tool_used")
  topic      String?
  duration   Int?     @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("learning_events")
}

model ProgressTracking {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  overallProgress     Int      @default(0) @map("overall_progress")
  learningLevel       Int      @default(1) @map("learning_level")
  learningLevelName   String   @default("Beginner") @map("learning_level_name")
  masteryScore        Int      @default(0) @map("mastery_score")
  masteryGrade        String   @default("Beginner") @map("mastery_grade")
  topicsCompleted     Int      @default(0) @map("topics_completed")
  documentsCompleted  Int      @default(0) @map("documents_completed")
  questionsPracticed  Int      @default(0) @map("questions_practiced")
  studySessions       Int      @default(0) @map("study_sessions")
  currentStreak       Int      @default(0) @map("current_streak")
  status              String   @default("Getting Started") @map("status")
  milestonesJson      Json     @default("[]") @map("milestones_json")
  revisionQueueJson   Json     @default("[]") @map("revision_queue_json")
  timelineJson        Json     @default("[]") @map("timeline_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("progress_tracking")
}

model TopicProgress {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  documentId          String?  @map("document_id")
  topicName           String   @map("topic_name")
  progressPercentage  Int      @default(0) @map("progress_percentage")
  masteryScore        Int      @default(0) @map("mastery_score")
  revisionStatus      Boolean  @default(false) @map("revision_status")
  questionsPracticed  Int      @default(0) @map("questions_practiced")
  conceptsCovered     Int      @default(0) @map("concepts_covered")
  totalConcepts       Int      @default(10) @map("total_concepts")
  lastActivity        DateTime @default(now()) @map("last_activity")
  status              String   @default("In Progress") @map("status")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("topic_progress")
}

model ConceptMastery {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  conceptName    String   @map("concept_name")
  topicName      String?  @map("topic_name")
  masteryScore   Int      @default(0) @map("mastery_score")
  interactions   Int      @default(0)
  revisionCount  Int      @default(0) @map("revision_count")
  practiceCount  Int      @default(0) @map("practice_count")
  lastReviewed   DateTime @default(now()) @map("last_reviewed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("concept_mastery")
}

model StudyPlan {
  id                   String      @id @default(cuid())
  userId               String      @map("user_id")
  title                String
  examDate             DateTime?   @map("exam_date")
  studyMode            String      @map("study_mode")
  dailyHours           Int         @map("daily_hours")
  targetScore          String      @map("target_score")
  completionPercentage Int         @default(0) @map("completion_percentage")
  planJson             Json        @map("plan_json")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  tasks                StudyTask[]

  @@map("study_plans")
}

model StudyTask {
  id            String    @id @default(cuid())
  studyPlanId   String    @map("study_plan_id")
  topicName     String    @map("topic_name")
  scheduledDate DateTime  @map("scheduled_date")
  priority      String
  status        String    @default("Pending")
  estimatedTime Int       @map("estimated_time")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  studyPlan     StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@map("study_tasks")
}

model StudyRevision {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  topicName    String   @map("topic_name")
  revisionDate DateTime @map("revision_date")
  revisionType String   @map("revision_type")
  status       String   @default("Pending")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("study_revisions")
}

model LearningStreak {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  currentStreak     Int       @default(0) @map("current_streak")
  longestStreak     Int       @default(0) @map("longest_streak")
  previousStreak    Int       @default(0) @map("previous_streak")
  consistencyScore  Int       @default(0) @map("consistency_score")
  lastActiveDate    DateTime? @map("last_active_date")
  activeDaysCount   Int       @default(0) @map("active_days_count")
  monthlyActivity   Json?     @map("monthly_activity") // format: { "YYYY-MM": [day1, day2, ...] }
  yearlyActivity    Json?     @map("yearly_activity")  // format: { "YYYY": count }
  streakRule        String    @default("action") @map("streak_rule") // "action" or "time"
  timeRequirement   Int       @default(10) @map("time_requirement") // in minutes
  streakFreezes     Int       @default(1) @map("streak_freezes")
  freezeActive      Boolean   @default(false) @map("freeze_active")
  globalRank        Int?      @map("global_rank")
  campusRank        Int?      @map("campus_rank")
  points            Int       @default(0) @map("points")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("learning_streaks")
}

model StreakEvent {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  eventType      String   @map("event_type")
  eventSource    String   @map("event_source")
  documentId     String?  @map("document_id")
  activityPoints Int      @default(0) @map("activity_points") // represents minutes of study or equivalent
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("streak_events")
}

model StreakAchievement {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  achievementName String   @map("achievement_name")
  achievementType String   @map("achievement_type")
  rarity          String   @map("rarity") // Common, Rare, Epic, Legendary
  unlockedAt      DateTime @default(now()) @map("unlocked_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("streak_achievements")
}

model WeakTopic {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  topicName            String   @map("topic_name")
  strengthScore        Int      @default(0) @map("strength_score")        // 0-100
  riskLevel            String   @default("Low") @map("risk_level")        // Low | Medium | High | Critical
  revisionPriority     String   @default("Optional") @map("revision_priority") // Immediate | This Week | This Month | Optional
  retentionProbability Int      @default(100) @map("retention_probability") // 0-100
  lastStudied          DateTime? @map("last_studied")
  status               String   @default("Average") @map("status")        // Excellent | Strong | Average | Weak | Critical
  questionAccuracy     Int      @default(0) @map("question_accuracy")     // 0-100 %
  revisionCount        Int      @default(0) @map("revision_count")
  studyTimeMinutes     Int      @default(0) @map("study_time_minutes")
  aiInteractionCount   Int      @default(0) @map("ai_interaction_count")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([userId, topicName])
  @@map("weak_topics")
}

model WeakConcept {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  topicName         String   @map("topic_name")
  conceptName       String   @map("concept_name")
  masteryScore      Int      @default(0) @map("mastery_score")   // 0-100
  riskLevel         String   @default("Low") @map("risk_level")  // Low | Medium | High | Critical
  recommendedAction String   @default("") @map("recommended_action")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([userId, topicName, conceptName])
  @@map("weak_concepts")
}

model RevisionQueue {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  topicName         String    @map("topic_name")
  priority          String    @default("Optional") @map("priority") // Immediate | This Week | This Month | Optional
  recommendedDate   DateTime? @map("recommended_date")
  reason            String    @default("") @map("reason")
  status            String    @default("Pending") @map("status")   // Pending | Done | Skipped
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("revision_queue")
}

model Recommendation {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  recommendationType String   @map("recommendation_type")
  topicName          String   @map("topic_name")
  priority           String
  impactScore        Int      @map("impact_score")
  urgencyScore       Int      @map("urgency_score")
  relevanceScore     Int      @map("relevance_score")
  reason             String
  status             String   @default("pending")
  generatedAt        DateTime @default(now()) @map("generated_at")
  expiresAt          DateTime @map("expires_at")

  @@map("recommendations")
}

// Master database models mapped in user database schema to prevent Prisma dropping tables/columns in local dev
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  profile   Profile?

  // Payment / Subscription Relations
  plan                String    @default("free")
  razorpayCustomerId  String?   @map("razorpay_customer_id")
  razorpaySubscriptionId String? @map("razorpay_subscription_id")
  subscriptionStatus  String?   @map("subscription_status")
  subscriptionEnd     DateTime? @map("subscription_end")
  payments            Payment[]

  @@map("users")
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  college           String?
  branch            String?
  phone             String?
  year              String?
  careerGoal        String?  @map("career_goal")
  skills            String[] @default([])
  linkedin          String?
  github            String?
  resumeUrl         String?  @map("resume_url")
  resumeName        String?  @map("resume_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  aboutMe           String?  @map("about_me")
  careerObjective   String?  @map("career_objective")
  degree            String?
  graduationYear    String?  @map("graduation_year")
  interestedDomains String[] @default([]) @map("interested_domains")
  location          String?
  portfolio         String?
  targetRole        String?  @map("target_role")
  username          String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  orderId   String   @unique @map("order_id")
  paymentId String?  @unique @map("payment_id")
  signature String?  @map("signature")
  amount    Int
  currency  String   @default("INR")
  plan      String
  status    String   @default("created")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_tokens")
}

enum Role {
  USER
  ADMIN
}



generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/user-client"
}

datasource db {
  provider = "postgresql"
}

model Resume {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  title          String
  template       String
  resumeData     Json             @map("resume_data")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  docxUrl        String?          @map("docx_url")
  pdfUrl         String?          @map("pdf_url")
  targetCompany  String?          @map("target_company")
  atsReports         ATSReport[]
  coverLetters       CoverLetter[]
  resumeAnalyses     ResumeAnalysis[]
  resumeImprovements ResumeImprovement[]
  resumeVersions     ResumeVersion[]

  @@index([userId])
  @@index([createdAt])
  @@map("resumes")
}

model ATSReport {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  resumeId        String   @map("resume_id")
  score           Int
  missingKeywords Json     @map("missing_keywords")
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  overallScore     Int?     @map("overall_score")
  formattingScore  Int?     @map("formatting_score")
  keywordScore     Int?     @map("keyword_score")
  experienceScore  Int?     @map("experience_score")
  projectScore     Int?     @map("project_score")
  skillsScore      Int?     @map("skills_score")
  educationScore   Int?     @map("education_score")
  readabilityScore Int?     @map("readability_score")
  reportJson       Json?    @map("report_json")

  @@index([userId])
  @@index([createdAt])
  @@map("ats_reports")
}

model ResumeAnalysis {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  resumeId        String   @map("resume_id")
  strengths       Json
  weaknesses      Json
  recommendations Json
  createdAt       DateTime @default(now()) @map("created_at")
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("resume_analyses")
}

model CoverLetter {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  companyName     String    @map("company_name")
  role            String
  content         String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  resumeId        String?   @map("resume_id")
  jobDescription  String?   @map("job_description")
  tone            String    @default("Professional")
  letterType      String    @default("Full-Time") @map("letter_type")
  greeting        String?
  introduction    String?
  body            String?
  closing         String?
  pdfUrl          String?   @map("pdf_url")
  docxUrl         String?   @map("docx_url")
  qualityScore    Int?      @map("quality_score")
  roleMatchScore  Int?      @map("role_match_score")
  atsScore        Int?      @map("ats_score")
  personalizationScore Int? @map("personalization_score")
  versionNumber   Int       @default(1) @map("version_number")
  isFavorite      Boolean   @default(false) @map("is_favorite")
  letterName      String?   @map("letter_name")
  parsedKeywords  String[]  @default([]) @map("parsed_keywords")
  highlightMap    Json?     @map("highlight_map")
  resume          Resume?   @relation(fields: [resumeId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("cover_letters")
}

model UploadedResume {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  cloudinaryUrl   String           @map("cloudinary_url")
  fileName        String           @map("file_name")
  fileType        String           @map("file_type")
  fileSize        Int              @map("file_size")
  versionNumber   Int              @default(1) @map("version_number")
  isActive        Boolean          @default(false) @map("is_active")
  extractedText   String?          @map("extracted_text")
  createdAt       DateTime         @default(now()) @map("created_at")
  candidateProfile CandidateProfile?

  @@index([userId])
  @@index([createdAt])
  @@map("uploaded_resumes")
}

model CandidateProfile {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  resumeId           String    @unique @map("resume_id")
  name               String?
  email              String?
  phone              String?
  location           String?
  summary            String?
  education          Json      @default("[]")
  experience         Json      @default("[]")
  projects           Json      @default("[]")
  skills             Json      @default("[]")
  certifications     Json      @default("[]")
  achievements       Json      @default("[]")
  languages          Json      @default("[]")
  links              Json      @default("{}")
  completenessScore  Int       @default(0) @map("completeness_score")
  strengthScore      Int       @default(0) @map("strength_score")
  missingSections    Json      @default("[]") @map("missing_sections")
  recommendations    Json      @default("[]")
  strengths          Json      @default("[]")
  weaknesses         Json      @default("[]")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  resume             UploadedResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([userId, resumeId])
  @@index([userId])
  @@map("candidate_profiles")
}

model LinkedInReport {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  headline            String   @default("")
  aboutSection        String   @default("") @map("about_section")
  skills              Json     @default("[]")
  recommendations     Json     @default("[]")
  score               Int      @default(0)

  experienceJson      Json?    @map("experience_json")
  projectsJson        Json?    @map("projects_json")
  featuredJson        Json?    @map("featured_json")
  networkingJson      Json?    @map("networking_json")
  contentIdeasJson    Json?    @map("content_ideas_json")

  headlineScore       Int?     @map("headline_score")
  aboutScore          Int?     @map("about_score")
  experienceScore     Int?     @map("experience_score")
  projectsScore       Int?     @map("projects_score")
  skillsScore         Int?     @map("skills_score")
  keywordScore        Int?     @map("keyword_score")
  visibilityScore     Int?     @map("visibility_score")
  completenessScore   Int?     @map("completeness_score")
  completenessJson    Json?    @map("completeness_json")

  targetRole          String?  @map("target_role")
  versionNumber       Int      @default(1) @map("version_number")
  versionLabel        String?  @map("version_label")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([createdAt])
  @@map("linkedin_reports")
}

model StudySession {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  topic     String
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  messages  StudyMessage[]
  documents UploadedDocument[]

  @@index([userId])
  @@index([createdAt])
  @@map("study_sessions")
}

model StudyMessage {
  id        String       @id @default(cuid())
  sessionId String       @map("session_id")
  role      String
  content   String
  createdAt DateTime     @default(now()) @map("created_at")
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("study_messages")
}

model UploadedDocument {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  sessionId String?       @map("session_id")
  fileName  String        @map("file_name")
  fileUrl   String        @map("file_url")
  fileType  String        @map("file_type")
  createdAt DateTime      @default(now()) @map("created_at")
  session   StudySession? @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("uploaded_documents")
}

model GeneratedNote {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  subject    String?
  difficulty String?
  type       String
  content    String
  formattedContent String? @map("formatted_content")
  pdfUrl     String?  @map("pdf_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([createdAt])
  @@index([topic])
  @@map("generated_notes")
}

model Quiz {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  topic      String
  difficulty String?
  questions  Json
  createdAt  DateTime      @default(now()) @map("created_at")
  flashcards Flashcard[]
  attempts   QuizAttempt[]

  @@index([userId])
  @@index([createdAt])
  @@map("quizzes")
}

model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  quizId       String   @map("quiz_id")
  score        Int
  total        Int
  accuracy     Float
  weakTopics   String[] @map("weak_topics")
  strongTopics String[] @map("strong_topics")
  createdAt    DateTime @default(now()) @map("created_at")
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([createdAt])
  @@map("quiz_attempts")
}

model Flashcard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  quizId    String?  @map("quiz_id")
  topic     String
  front     String
  back      String
  createdAt DateTime @default(now()) @map("created_at")
  quiz      Quiz?    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([topic])
  @@map("flashcards")
}

model Assignment {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  topic         String
  academicLevel String   @map("academic_level")
  wordCount     Int      @map("word_count")
  content       Json
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("assignments")
}

model Presentation {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  topic      String
  slideCount Int      @map("slide_count")
  audience   String?
  style      String?
  slides     Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("presentations")
}

model MindMap {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  topic     String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("mind_maps")
}

model CodingSession {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  title     String
  mode      String          @default("generate")
  languages String[]        @default(["javascript"])
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  messages  CodingMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("coding_sessions")
}

model CodingMessage {
  id          String        @id @default(cuid())
  sessionId   String        @map("session_id")
  role        String
  content     String
  mode        String?
  results     Json?
  codeSnippet String?
  errorMsg    String?
  languages   String[]
  createdAt   DateTime      @default(now()) @map("created_at")
  session     CodingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("coding_messages")
}

model Problem {
  id          String       @id @default(cuid())
  title       String
  difficulty  String
  category    String
  companies   String[]
  statement   String
  constraints String
  examples    Json
  hints       String[]
  editorial   String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  submissions Submission[]

  @@map("problems")
}

model Submission {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  problemId String   @map("problem_id")
  code      String
  language  String
  status    String
  timeMs    Int?
  memoryKb  Int?
  aiReview  Json?
  createdAt DateTime @default(now()) @map("created_at")
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([problemId])
  @@index([createdAt])
  @@map("submissions")
}

model ProblemWorkspaceSession {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  questionId  String   @map("question_id")
  language    String
  codeContent String   @map("code_content")
  status      String   @default("In Progress")
  timeSpent   Int      @default(0) @map("time_spent")
  lastOpened  DateTime @default(now()) @map("last_opened")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
  @@map("problem_workspace_sessions")
}

model ProblemNote {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  questionId  String   @map("question_id")
  noteContent String   @map("note_content")
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([questionId])
  @@map("problem_notes")
}

model ProblemBookmark {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
  @@map("problem_bookmarks")
}

model ProblemDiscussion {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([questionId])
  @@index([createdAt])
  @@map("problem_discussions")
}

model DSAProgress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  solved    Int      @default(0)
  accuracy  Float    @default(0)
  streak    Int      @default(0)
  ranking   Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("dsa_progress")
}

model ChallengeCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String
  icon        String
  gradient    String
  color       String
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  challenges  Challenge[]

  @@map("challenge_categories")
}

model Challenge {
  id          String               @id @default(cuid())
  categoryId  String               @map("category_id")
  slug        String               @unique
  title       String
  difficulty  String
  points      Int
  description String
  topics      String[]
  testCases   Json?
  timeLimit   Int?
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime             @default(now()) @map("created_at")
  category    ChallengeCategory    @relation(fields: [categoryId], references: [id])
  submissions ChallengeSubmission[]

  @@index([categoryId])
  @@map("challenges")
}

model ChallengeSubmission {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  challengeId String    @map("challenge_id")
  code        String
  language    String
  score       Int       @default(0)
  status      String
  createdAt   DateTime  @default(now()) @map("created_at")
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeId])
  @@index([createdAt])
  @@map("challenge_submissions")
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  score     Int      @default(0)
  rank      Int?
  badges    String[]
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("leaderboards")
}

model GithubProfile {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  username   String
  repos      Json
  languages  Json
  stars      Int      @default(0)
  commits    Int      @default(0)
  lastSynced DateTime @default(now()) @map("last_synced")

  @@index([userId])
  @@map("github_profiles")
}

model GeneratedReadme {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  projectName String
  content     String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("generated_readmes")
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  theme       String   @default("default")
  content     Json
  isPublished Boolean  @default(false)
  url         String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([createdAt])
  @@map("portfolios")
}

model InterviewSession {
  id                   String             @id @default(cuid())
  userId               String             @map("user_id")
  role                 String
  company              String?
  type                 String
  difficulty           String             @default("medium")
  language             String             @default("english")
  durationMinutes      Int                @default(30)
  technology           String?
  aiVoiceEnabled       Boolean            @default(true) @map("ai_voice_enabled")
  videoEnabled         Boolean            @default(true) @map("video_enabled")
  status               String             @default("in_progress")
  violationPoints      Int                @default(0) @map("violation_points")
  violationThreshold   Int                @default(10) @map("violation_threshold")
  feedback             Json?
  configuration        Json?
  identityVerification Json?              @map("identity_verification")
  deviceInfo           Json?              @map("device_info")
  systemCheck          Json?              @map("system_check")
  startedAt            DateTime?          @map("started_at")
  endedAt              DateTime?          @map("ended_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  messages             InterviewMessage[]
  violations           ProctoringEvent[]
  evaluations          InterviewEvaluation[]

  @@index([userId])
  @@index([createdAt])
  @@map("interview_sessions")
}

model InterviewMessage {
  id        String           @id @default(cuid())
  sessionId String           @map("session_id")
  role      String
  content   String
  audioUrl  String?          @map("audio_url")
  duration  Int?             @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("interview_messages")
}

model ProctoringEvent {
  id              String           @id @default(cuid())
  sessionId       String           @map("session_id")
  eventType       String           @map("event_type")
  category        String
  description     String
  confidence      Float            @default(0)
  screenshotData  String?          @map("screenshot_data")
  severity        String           @default("info")
  actionTaken     String?          @map("action_taken")
  pointsDeducted  Int              @default(0) @map("points_deducted")
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  session         InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("proctoring_events")
}

model InterviewEvaluation {
  id                String           @id @default(cuid())
  sessionId         String           @map("session_id")
  overallScore      Int              @map("overall_score")
  communicationScore Int             @map("communication_score")
  technicalScore    Int?             @map("technical_score")
  hrScore           Int?             @map("hr_score")
  confidenceScore   Int?             @map("confidence_score")
  fluencyScore      Int?             @map("fluency_score")
  bodyLanguageScore Int?             @map("body_language_score")
  strengths         Json
  weaknesses        Json
  improvements      Json
  summary           String
  hiringRecommendation String        @map("hiring_recommendation")
  detailedAnalysis  Json?            @map("detailed_analysis")
  createdAt         DateTime         @default(now()) @map("created_at")
  session           InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("interview_evaluations")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  title     String        @default("New Chat")
  model     String        @default("openai/gpt-4o-mini")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  role      String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model LearningAnalytics {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  documentsCount     Int      @default(0) @map("documents_count")
  studyTimeMinutes   Int      @default(0) @map("study_time_minutes")
  conceptsLearned    Int      @default(0) @map("concepts_learned")
  learningScore      Int      @default(0) @map("learning_score")
  examReadiness      Int      @default(0) @map("exam_readiness")
  currentStreak      Int      @default(0) @map("current_streak")
  longestStreak      Int      @default(0) @map("longest_streak")
  toolUsageJson      Json     @map("tool_usage_json")
  topicAnalyticsJson Json     @map("topic_analytics_json")
  recommendationsJson Json    @map("recommendations_json")
  insightsJson       Json     @map("insights_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("learning_analytics")
}

model LearningEvent {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  eventType  String   @map("event_type")
  documentId String?  @map("document_id")
  toolUsed   String?  @map("tool_used")
  topic      String?
  duration   Int?     @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([documentId])
  @@index([createdAt])
  @@map("learning_events")
}

model ProgressTracking {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  overallProgress     Int      @default(0) @map("overall_progress")
  learningLevel       Int      @default(1) @map("learning_level")
  learningLevelName   String   @default("Beginner") @map("learning_level_name")
  masteryScore        Int      @default(0) @map("mastery_score")
  masteryGrade        String   @default("Beginner") @map("mastery_grade")
